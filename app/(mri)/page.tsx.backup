// ─── Operational Blueprint Background ────────────────────────────
// Replaces the generic neural network with a concept grounded in tracking
// fragmented work signals into a coordinated execution layer.

const BlueprintNode = ({
  cx,
  cy,
  color,
  isDark,
  label,
  delay = 0,
}: {
  cx: number
  cy: number
  color: string
  isDark: boolean
  label?: string
  delay?: number
}) => (
  <motion.g initial={{ opacity: 0, scale: 0 }} animate={{ opacity: 1, scale: 1 }} transition={{ delay, duration: 1 }}>
    {/* Glow */}
    <motion.circle
      cx={cx}
      cy={cy}
      r="20"
      fill={color}
      initial={{ opacity: 0.1 }}
      animate={{ opacity: [0.1, 0.3, 0.1], r: [20, 30, 20] }}
      transition={{ duration: 4, repeat: Infinity, delay: delay + 0.5 }}
    />
    {/* Inner node */}
    <circle cx={cx} cy={cy} r="6" fill={isDark ? "#111827" : "#ffffff"} stroke={color} strokeWidth="3" />

    {label && (
      <text
        x={cx}
        y={cy - 25}
        textAnchor="middle"
        className={`font-syne text-[10px] font-bold uppercase tracking-wider ${
          isDark ? "fill-gray-500" : "fill-gray-400"
        }`}
      >
        {label}
      </text>
    )}
  </motion.g>
)

const SignalPath = ({ d, color, delay = 0 }: { d: string; color: string; delay?: number }) => (
  <>
    {/* Base faint path */}
    <path
      d={d}
      fill="none"
      stroke={color}
      strokeWidth="1"
      strokeOpacity="0.2"
      className="stroke-dasharray-4"
      strokeDasharray="4 4"
    />
    {/* Animated signal pulse */}
    <motion.path
      d={d}
      fill="none"
      stroke={color}
      strokeWidth="2"
      initial={{ pathLength: 0, opacity: 0 }}
      animate={{ pathLength: [0, 1], opacity: [0, 1, 0] }}
      transition={{ duration: 3, repeat: Infinity, delay, ease: "easeInOut" }}
    />
  </>
)

const OperationalBlueprintBackground = ({ isDark, colors }: { isDark: boolean; colors: any }) => {
  return (
    <div className="pointer-events-none absolute inset-0 overflow-hidden opacity-60">
      {/* SVG spans full width and height of its container */}
      <svg className="absolute inset-0 h-full w-full" viewBox="-400 180 1650 900" preserveAspectRatio="xMidYMin slice">
        {/* Mobile Layout (Tight cropping adjustment) */}
        <g className="md:hidden">
          {/* Email Signal */}
          <SignalPath d="M 100 250 L 260 250 C 300 250, 320 400, 350 400" color={colors.blue} delay={0} />
          <BlueprintNode cx={260} cy={250} color={colors.blue} isDark={isDark} label="EMAIL" delay={0.2} />

          {/* Slack/Chat Signal */}
          <SignalPath d="M 100 350 L 240 350 C 300 350, 320 400, 350 400" color={colors.purple} delay={1.2} />
          <BlueprintNode cx={240} cy={350} color={colors.purple} isDark={isDark} label="CHAT" delay={0.5} />

          {/* Meetings Signal */}
          <SignalPath d="M 100 500 L 230 500 C 300 500, 320 400, 350 400" color={colors.emerald} delay={0.8} />
          <BlueprintNode cx={230} cy={500} color={colors.emerald} isDark={isDark} label="MEETING" delay={0.8} />

          {/* Task Created */}
          <SignalPath d="M 500 400 C 530 400, 550 250, 590 250 L 750 250" color={colors.amber} delay={2.0} />
          <BlueprintNode cx={590} cy={250} color={colors.amber} isDark={isDark} label="TASK SYNC" delay={1.5} />

          {/* Follow-up Scheduled */}
          <SignalPath d="M 500 400 C 530 400, 550 550, 610 550 L 750 550" color={colors.pink} delay={2.5} />
          <BlueprintNode cx={610} cy={550} color={colors.pink} isDark={isDark} label="FOLLOW-UP" delay={1.8} />
        </g>

        {/* Desktop Layout (Wide spacious layout) */}
        <g className="hidden md:block">
          {/* Email Signal */}
          <SignalPath d="M -800 250 L -150 250 C 50 250, 150 400, 350 400" color={colors.blue} delay={0} />
          <BlueprintNode cx={-150} cy={250} color={colors.blue} isDark={isDark} label="EMAIL" delay={0.2} />

          {/* Slack/Chat Signal */}
          <SignalPath d="M -800 350 L -130 350 C 50 350, 150 400, 350 400" color={colors.purple} delay={1.2} />
          <BlueprintNode cx={-130} cy={350} color={colors.purple} isDark={isDark} label="CHAT" delay={0.5} />

          {/* Meetings Signal */}
          <SignalPath d="M -800 500 L -160 500 C 50 500, 150 400, 350 400" color={colors.emerald} delay={0.8} />
          <BlueprintNode cx={-160} cy={500} color={colors.emerald} isDark={isDark} label="MEETING" delay={0.8} />

          {/* Task Created */}
          <SignalPath d="M 500 400 C 700 400, 800 250, 1000 250 L 1600 250" color={colors.amber} delay={2.0} />
          <BlueprintNode cx={1000} cy={250} color={colors.amber} isDark={isDark} label="TASK SYNC" delay={1.5} />

          {/* Follow-up Scheduled */}
          <SignalPath d="M 500 400 C 700 400, 800 550, 1030 550 L 1600 550" color={colors.pink} delay={2.5} />
          <BlueprintNode cx={1030} cy={550} color={colors.pink} isDark={isDark} label="FOLLOW-UP" delay={1.8} />
        </g>

        {/* Center: The Coordinated Execution Trunk (Shared) */}
        <motion.path
          d="M 350 400 L 500 400"
          fill="none"
          stroke={isDark ? "#4b5563" : "#9ca3af"}
          strokeWidth="4"
          initial={{ pathLength: 0 }}
          animate={{ pathLength: 1 }}
          transition={{ duration: 1.5, delay: 1 }}
        />

        {/* Animated flow across the trunk */}
        <motion.path
          d="M 350 400 L 500 400"
          fill="none"
          stroke={colors.blue}
          strokeWidth="4"
          initial={{ pathLength: 0, opacity: 0 }}
          animate={{ pathLength: [0, 1], opacity: [0, 1, 0] }}
          transition={{ duration: 2, repeat: Infinity, delay: 1.5 }}
        />

        {/* Core Processing Node */}
        <motion.g
          initial={{ opacity: 0, scale: 0 }}
          animate={{ opacity: 1, scale: 1 }}
          transition={{ delay: 1, duration: 1, type: "spring" }}
        >
          {/* Pulse ring */}
          <motion.circle
            cx={425}
            cy={400}
            r="35"
            fill="none"
            stroke={colors.blue}
            strokeWidth="1"
            initial={{ scale: 1, opacity: 0.5 }}
            animate={{ scale: 2, opacity: 0 }}
            transition={{ duration: 2, repeat: Infinity }}
          />
          {/* Hexagon core */}
          <polygon
            points="425,380 442,390 442,410 425,420 408,410 408,390"
            fill={isDark ? "#1f2937" : "#ffffff"}
            stroke={colors.blue}
            strokeWidth="2"
          />
          <text
            x={425}
            y={370}
            textAnchor="middle"
            className={`font-syne text-[10px] font-bold uppercase tracking-[0.2em] ${
              isDark ? "fill-blue-400" : "fill-blue-600"
            }`}
          >
            CORTIFACT
          </text>
        </motion.g>

        {/* Lower decorative horizontal lines */}
        <path
          d="M -800 800 L 1600 800"
          stroke={isDark ? "#374151" : "#e5e5e5"}
          strokeWidth="1"
          strokeDasharray="10 10"
        />

        {/* Mobile Memory Node */}
        <g className="md:hidden">
          <BlueprintNode cx={425} cy={800} color={colors.emerald} isDark={isDark} label="MEMORY" delay={3} />
          <SignalPath d="M 425 800 L 800 800" color={colors.emerald} delay={3.5} />
        </g>

        {/* Desktop Memory Node */}
        <g className="hidden md:block">
          <BlueprintNode cx={300} cy={800} color={colors.emerald} isDark={isDark} label="MEMORY" delay={3} />
          <SignalPath d="M 300 800 L 1600 800" color={colors.emerald} delay={3.5} />
        </g>
      </svg>
    </div>
  )
}

