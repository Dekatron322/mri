                  isDark ? "text-gray-100" : "text-gray-900"
                }`}
              >
                Build on a System
                <br />
                That Remembers.
              </h2>
              <ScrollIlluminatedText
                isDark={isDark}
                className="mx-auto mt-4 max-w-md text-sm font-light leading-relaxed"
              >
                Help your team remember more, coordinate better, and follow through with less friction. Starting with a
                Project Manager blueprint and expanding into a broader platform for operational continuity.
              </ScrollIlluminatedText>
            </motion.div>

            <div className="mt-8 flex flex-wrap justify-center gap-2">
              {[
                "Continuity",
                "Follow-Through",
                "Operational Intelligence",
                "Blueprints",
                "Coordinated Execution",
                "Durable Memory",
              ].map((tag, i) => (
                <span
                  key={i}
                  className={`rounded-full border px-3.5 py-1.5 text-[11px] font-medium uppercase tracking-wide ${
                    isDark ? "border-gray-800 text-gray-500" : "border-gray-200 text-gray-400"
                  }`}
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>

          {/* Footer */}
          <div
            className={`mt-12 flex items-center justify-between border-t py-8 ${
              isDark ? "border-gray-800" : "border-gray-200"
            }`}
          >
            <img src={isDark ? "/cortifact-dark.png" : "/cortifact-light.png"} alt="Cortifact" className="h-8" />
            <span className={`text-[11px] uppercase tracking-[0.1em] ${isDark ? "text-gray-600" : "text-gray-400"}`}>
              Cortifacts
            </span>
          </div>
        </motion.div>

        <div className="mt-12 flex justify-center">
          <motion.button
            whileHover={{ scale: 1.02 }}
            whileTap={{ scale: 0.98 }}
            onClick={() => setIsWaitlistModalOpen(true)}
            className={`group inline-flex h-12 items-center justify-center gap-2 rounded-full px-8 py-3 text-sm font-medium shadow-sm transition-all hover:shadow-lg ${
              isDark ? "bg-white text-black hover:bg-gray-200" : "bg-gray-900 text-white hover:bg-gray-800"
            }`}
          >
            Request Early Access
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              className="transition-transform group-hover:translate-x-0.5"
            >
              <path
                d="M8 1L15 8L8 15M15 8H1"
                stroke="currentColor"
                strokeWidth="1.5"
                strokeLinecap="round"
                strokeLinejoin="round"
              />
            </svg>
          </motion.button>
        </div>
      </div>

      {/* Theme Toggle */}
      <ThemeToggle isDark={isDark} toggle={toggleTheme} />
    </main>
  )
}
